# Production Configuration for AI Video Platform
# Copy to .env and fill in your values

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_DB=aivideo
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# API
API_PORT=8000
FRONTEND_PORT=3000
FLOWER_PORT=5555

# Security
JWT_SECRET=CHANGE_ME_SECURE_RANDOM_STRING_32_CHARS

# Model API Keys
# KIE.ai — unified API for ALL models (primary for testing)
KIE_API_KEY=your_kie_api_key

# Direct providers (fallback / legacy)
OPENAI_API_KEY=sk-...
SEEDANCE_API_KEY=your_seedance_key
KLING_ACCESS_KEY=your_kling_access_key
KLING_SECRET_KEY=your_kling_secret_key

# Storage backend: "local" (dev) or "s3" (S3 / Cloudflare R2 / OSS in prod)
STORAGE_TYPE=local
STORAGE_PATH=/tmp/aivideo-media
# Optional CDN origin for locally-served media (leave empty for relative URLs)
# MEDIA_CDN_BASE_URL=https://cdn.example.com
#
# Production object storage (activated when STORAGE_TYPE=s3):
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET=aivideo-media
# AWS_REGION=auto                      # "auto" for Cloudflare R2
# AWS_S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com   # R2/OSS endpoint
# S3_PUBLIC_BASE_URL=https://cdn.example.com   # public CDN base for served objects
# S3_KEY_PREFIX=media

# CORS
CORS_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Stripe (production billing)
# STRIPE_API_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER_MONTHLY=price_...
# STRIPE_PRICE_STARTER_YEARLY=price_...
# STRIPE_PRICE_PERSONAL_MONTHLY=price_...
# STRIPE_PRICE_PERSONAL_YEARLY=price_...
# STRIPE_PRICE_CREATOR_MONTHLY=price_...
# STRIPE_PRICE_CREATOR_YEARLY=price_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_YEARLY=price_...
# STRIPE_PRICE_TEAM_SEAT_MONTHLY=price_...
