{
  "dashboard": {
    "title": "Betty VIS — Viral Intelligence Dashboard",
    "uid": "betty-vis",
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Topics by Viral Tier",
        "type": "stat",
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
        "targets": [
          {"expr": "vis_topics_by_tier{tier=\"tier_1_breakout\"}", "legendFormat": "Breakout"},
          {"expr": "vis_topics_by_tier{tier=\"tier_2_trending\"}", "legendFormat": "Trending"},
          {"expr": "vis_topics_by_tier{tier=\"tier_3_emerging\"}", "legendFormat": "Emerging"}
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "red", "value": 5}]}
          }
        }
      },
      {
        "id": 2,
        "title": "Total Topics Tracked",
        "type": "stat",
        "gridPos": {"x": 6, "y": 0, "w": 3, "h": 4},
        "targets": [{"expr": "vis_topics_total"}],
        "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}}
      },
      {
        "id": 3,
        "title": "Signals (24h)",
        "type": "stat",
        "gridPos": {"x": 9, "y": 0, "w": 3, "h": 4},
        "targets": [{"expr": "vis_signals_recent_24h"}],
        "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "orange", "value": 10}, {"color": "red", "value": 50}]}}}
      },
      {
        "id": 4,
        "title": "Circuit Breaker Status",
        "type": "stat",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 4},
        "targets": [
          {"expr": "vis_circuit_breaker_open{source=\"reddit\"}", "legendFormat": "Reddit"},
          {"expr": "vis_circuit_breaker_open{source=\"youtube\"}", "legendFormat": "YouTube"}
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]},
            "mappings": [{"type": "value", "value": "0", "text": "Closed"}, {"type": "value", "value": "1", "text": "OPEN"}]
          }
        }
      },
      {
        "id": 10,
        "title": "Topics by Tier (Time Series)",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
        "targets": [
          {"expr": "vis_topics_by_tier", "legendFormat": "{{tier}}"}
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {"fillOpacity": 15, "lineWidth": 2, "spanNulls": true}
          }
        }
      },
      {
        "id": 11,
        "title": "Topics by Platform",
        "type": "piechart",
        "gridPos": {"x": 12, "y": 4, "w": 6, "h": 8},
        "targets": [
          {"expr": "vis_topics_by_source", "legendFormat": "{{platform}}"}
        ]
      },
      {
        "id": 12,
        "title": "Signals Rate (24h)",
        "type": "timeseries",
        "gridPos": {"x": 18, "y": 4, "w": 6, "h": 8},
        "targets": [
          {"expr": "rate(vis_signals_recent_24h[5m])", "legendFormat": "Signals/min"}
        ]
      },
      {
        "id": 20,
        "title": "Breakout Alerts",
        "type": "table",
        "gridPos": {"x": 0, "y": 12, "w": 24, "h": 8},
        "targets": [
          {"expr": "vis_topics_by_tier{tier=\"tier_1_breakout\"} > 0"}
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {"align": "auto"},
            "thresholds": {"steps": [{"color": "red", "value": 0}]}
          }
        }
      }
    ],
    "schemaVersion": 38,
    "tags": ["betty", "vis", "viral-intelligence"]
  }
}
